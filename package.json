{
  "name": "mfe_shell_app",
  "version": "0.1.0",
  "scripts": {
    "reset": "npx rimraf node_modules ./**/node_modules",
    "dev": "modern dev",
    "build": "modern build",
    "start": "modern start",
    "serve": "modern serve",
    "new": "modern new",
    "lint": "biome check",
    "prepare": "simple-git-hooks",
    "upgrade": "modern upgrade",
    "builder-fusion": "concurrently --names \"shell,feature1,feature2\" --prefix name --kill-others \"cd ../multi-repo-mfe-remote-feature-1 && npm run dev\" \"cd ../multi-repo-mfe-remote-feature-2 && npm run dev\" \"wait-on http-get://localhost:3001/@mf-types.zip http-get://localhost:3002/@mf-types.zip && npm run dev\" "
  },
  "engines": {
    "node": ">=16.18.1"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@modern-js/runtime": "0.0.0-canary-20260129131527",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.8.3",
    "@modern-js/app-tools": "0.0.0-canary-20260129131527",
    "@modern-js/tsconfig": "0.0.0-canary-20260129131527",
    "@module-federation/modern-js-v3": "^2.3.2",
    "@types/jest": "~29.2.4",
    "@types/node": "~18.11.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "~18.3.1",
    "concurrently": "^9.2.1",
    "lint-staged": "~13.1.0",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "~5.0.4",
    "wait-on": "^9.0.5"
  }
}
